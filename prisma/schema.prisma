generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Quiz {
  id        Int       @id @default(autoincrement())
  question  String    @db.VarChar(255)
  answer    String    @db.VarChar(255)
  date      DateTime
  keywords  Keyword[]

  @@map("quizzes")
}

model Keyword {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)
  quizzes Quiz[]

  @@map("keywords")
}
